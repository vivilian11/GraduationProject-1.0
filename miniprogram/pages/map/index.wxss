.map-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.main-map {
  flex: 1;
  width: 100%;
}

.bottom-panel {
  padding: 16px 20px 32px;
  background: #fff;
  border-top: 0.5px solid #e8e8e8;
  border-radius: 16px 16px 0 0;
}

.panel-title {
  font-size: 16px;
  font-weight: 500;
  color: #222;
  display: block;
}

.panel-desc {
  font-size: 13px;
  color: #999;
  margin-top: 4px;
  display: block;
}

.btn-row {
  margin-top: 14px;
}

.btn-locate {
  width: 100%;
  height: 42px;
  line-height: 42px;
  background: #4CAF50;
  color: #fff;
  font-size: 14px;
  border-radius: 10px;
  border: none;
}