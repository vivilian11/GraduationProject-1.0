/* pages/index/index.wxss */
.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header {
  margin-top: 40rpx;
  text-align: center;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #07C160; /* 环保绿 */
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: #888;
  margin-top: 10rpx;
}

.main-action {
  margin-top: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.camera-btn {
  width: 350rpx;
  height: 350rpx;
  background-color: #f0fdf4;
  border: 4rpx dashed #07C160;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-shadow: 0 10rpx 20rpx rgba(7, 193, 96, 0.1);
}

.camera-img {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

.tip {
  margin-top: 30rpx;
  font-size: 24rpx;
  color: #b2b2b2;
}

.info-card {
  margin-top: 100rpx;
  width: 100%;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.card-title {
  font-weight: bold;
  font-size: 32rpx;
  margin-bottom: 10rpx;
  color: #333;
}